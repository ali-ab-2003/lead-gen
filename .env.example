# ── Data acquisition (Apify) ─────────────────────────────────────────────
# Get a token at https://console.apify.com/account/integrations
APIFY_TOKEN=
# Apify Google Maps Scraper actor id (default is the official one)
APIFY_GMAPS_ACTOR=nwua9Gu5YrADL7ZDj

# ── Storage (Supabase) ───────────────────────────────────────────────────
# Project URL + service_role key from Supabase project settings -> API
SUPABASE_URL=
SUPABASE_KEY=

# ── Google Sheets export ─────────────────────────────────────────────────
# Path to the service-account JSON key file (mounted/available at runtime).
# In Jenkins this is provided via a credentials file binding.
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-service-account.json
# The target spreadsheet (open it once and copy the id from the URL)
GOOGLE_SHEET_ID=

# ── AI enrichment (Groq, free tier) ──────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Behaviour toggles ────────────────────────────────────────────────────
# Set to 1 to skip the AI enrichment stage (keeps everything fully free / offline-ish)
DISABLE_AI=0
# Set to 1 to skip the contact-enrichment stage
DISABLE_ENRICH=0

# Streamlit secrets template.
#
# LOCAL: copy this file to `.streamlit/secrets.toml` and fill in the values.
# STREAMLIT CLOUD: paste these two lines (with real values) into
#   App -> Settings -> Secrets   (do NOT commit the real secrets.toml)
#
# The dashboard only needs read access to Supabase — no Apify/Groq/Google keys.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-supabase-key"
